{
  "name": "depmap",
  "version": "0.1.0",
  "description": "Live dependency visualizer for JavaScript/TypeScript projects",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "depmap": "dist/cli.js"
  },
  "scripts": {
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "dev": "tsc --watch",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "node dist/cli.js",
    "lint": "eslint src/ && cd frontend && eslint src/",
    "lint:fix": "eslint src/ --fix && cd frontend && eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "dependency",
    "graph",
    "visualization",
    "circular-dependencies",
    "typescript",
    "javascript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "open": "^11.0.0",
    "ts-morph": "^27.0.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
